# =============================================================================
# Inoyu OSS UI — environment template
# =============================================================================
# Usage:
#   cp .env.example .env.local
#   Uncomment only the variables you need to override.
#
# Shared defaults (Unomi / auth / deployment / app) are defined in code:
#   src/config/env-defaults.ts
# Keep this file and inoyu-pro-ui/.env.example in sync for those sections.
#
# Legend:
#   (default: …)  — value used by the app if the variable is omitted
#   (required)    — no code default; must be set for that feature to work
# =============================================================================

# ─── Unomi server ──────────────────────────────────────────────────────────

# Base URL of the Unomi CDP (server-side and public).
# (default: http://localhost:8181)
# UNOMI_URL=http://localhost:8181
# NEXT_PUBLIC_UNOMI_URL=http://localhost:8181

# Unomi version string. Tenant UI/APIs require 3.1+.
# Bare "3" or "3.0" is treated as 3.0 (no tenant UI).
# (default: 3.1)
# UNOMI_VERSION=3.1

# System (karaf) credentials used for admin/bootstrap Unomi calls.
# (default: karaf / karaf)
# UNOMI_USER=karaf
# UNOMI_PASSWORD=karaf

# Optional pinned tenant id. Prefer omitting on on-prem 3.1+ and creating
# tenants in the UI (Tenant Management / sidebar switcher).
# (default: unset — none)
# UNOMI_TENANT_ID=

# ─── Authentication ────────────────────────────────────────────────────────

# Secret for signing session JWTs.
# (required — no code default)
# JWT_SECRET=

# System admin login for the UI (first bootstrap / tenant management).
# (default: admin@inoyu.local / admin)
# ADMIN_EMAIL=admin@inoyu.local
# ADMIN_PASSWORD=admin

# ─── Deployment ────────────────────────────────────────────────────────────
#
#   |                | SaaS (multi-tenant)     | On-premise (managed)        |
#   |----------------|-------------------------|-----------------------------|
#   | Unomi < 3.1    | No tenant UI            | No tenant UI                |
#   | Unomi >= 3.1   | Tenant from JWT only;   | Tenant Management UI +      |
#   |                | no tenant switcher      | sidebar switcher            |
#
# (default: on-premise)
# DEPLOYMENT_TYPE=on-premise

# Optional explicit override for tenant admin UI/APIs.
# If unset, follows DEPLOYMENT_TYPE (on-premise → on, multi-tenant → off).
# Still requires Unomi >= 3.1 via UNOMI_VERSION.
# (default: unset — derived from DEPLOYMENT_TYPE)
# TENANT_ADMIN_ENABLED=true
# TENANT_ADMIN_ENABLED=false

# --- Example: SaaS (dynamic multi-tenant) ---
# DEPLOYMENT_TYPE=multi-tenant
# TENANT_ADMIN_ENABLED=false
# UNOMI_VERSION=3.1

# --- Example: Unomi before 3.1 (no tenant UI) ---
# UNOMI_VERSION=3.0
# DEPLOYMENT_TYPE=on-premise

# ─── App ─────────────────────────────────────────────────────────────────────

# Listen port (also hardcoded in npm scripts as -p 3131).
# (default: 3131)
# PORT=3131

# Public base URL of this app.
# (default: http://localhost:3131)
# NEXT_PUBLIC_BASE_URL=http://localhost:3131
